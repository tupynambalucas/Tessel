{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@tessel/core": ["../packages/core/src/index.ts"]
    }
  },
  "include": [
    "electron.vite.config.*", 
    "src/main/**/*", 
    "src/preload/**/*", 
    "src/env.d.ts"
  ],
  "exclude": [
    "src/renderer", 
    "out", 
    "dist", 
    "node_modules"
  ]
}