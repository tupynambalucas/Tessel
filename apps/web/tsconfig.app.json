{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      /* Mapeamento para desenvolvimento instantâneo (HMR) */
      "@tessel/game": ["../../packages/game/src/index.ts"],
      "@tessel/core": ["../../packages/core/src/index.ts"]
    },
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../../packages/game/tsconfig.build.json" },
    { "path": "../../packages/core" }
  ]
}
