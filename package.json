{
  "name": "@devtupynambalucas/tessel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "studio",
    "apps/*"
  ],
  "scripts": {
    "// CLIENTS ": "----------------------------------------------------",
    "dev:client-web": "npm run dev -w @tessel/client-web",
    "build:client-web": "npm run dev -w @tessel/client-web",
    "dev:client-desktop": "npm run dev -w @tessel/client-desktop",
    "build:client-desktop": "npm run dev -w @tessel/client-desktop",
    "// API ": "----------------------------------------------------",
    "dev:api": "npm run dev -w @tessel/api",
    "build:api": "npm run dev -w @tessel/api",
    "start:api": "npm run start -w @tessel/api",
    "seed:api": "npm run seed -w @tessel/api",
    "// [4] INFRAESTRUTURA LOCAL (DOCKER)": "---------------------------------------------",
    "infra:keygen": "node -e \"const fs=require('fs'); if(!fs.existsSync('mongo-keyfile')){fs.writeFileSync('mongo-keyfile', require('crypto').randomBytes(756).toString('base64')); console.log('✅ mongo-keyfile gerado com sucesso!')} else {console.log('ℹ️ mongo-keyfile já existe.')}\"",
    "infra:up": "npm run infra:keygen && docker compose up -d db redis",
    "infra:stop": "docker compose stop",
    "infra:down": "docker compose down",
    "infra:clean": "docker compose down --volumes && node -e \"const fs=require('fs'); if(fs.existsSync('mongo-keyfile')) fs.unlinkSync('mongo-keyfile')\"",
    "infra:reset": "npm run infra:clean && npm run infra:up",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@react-three/eslint-plugin": "^0.1.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "shx": "^0.4.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.0.5"
  },
  "overrides": {
    "@tessel/studio": "*",
    "@tessel/core": "*",
    "@xstate/react": "6.0.0",
    "@gsap/react": "2.1.2",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.5.0",
    "@react-three/postprocessing": "3.0.4",
    "@react-three/rapier": "2.2.0",
    "three": "0.182.0",
    "gsap": "3.14.2",
    "i18next": "25.8.4",
    "react-i18next": "16.5.4",
    "tone": "15.1.22",
    "zustand": "5.0.11",
    "tailwindcss": "4.1.18",
    "zod": "4.3.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "axios": "1.15.1",
    "date-fns": "4.1.0",
    "react-datepicker": "9.1.0"
  }
}
