{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@tessel/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../core" }]
}
