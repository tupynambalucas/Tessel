{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /* Força o rigor de ESM (exige extensões .js nos imports) */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
