{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* Habilita a emissão de arquivos */
    "noEmit": false,
    "outDir": "./dist",

    /* Configuração para Monorepos (Project References) */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "emitDeclarationOnly": true,

    /* Limpeza de código */
    "removeComments": true
  },
  "exclude": ["node_modules", "dist", "**/*.test.*", "**/*.spec.*", "**/*.css", "**/*.module.css"],
  "references": [{ "path": "../core" }]
}
